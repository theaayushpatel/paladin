# Paladin Protocol Environment Variables

# API Keys
ALCHEMY_API_KEY=your_alchemy_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here
ARBISCAN_API_KEY=your_arbiscan_api_key_here

# Wallet
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Contract Addresses (will be populated after deployment)
GUARDIAN_ADDRESS=
RISK_REGISTRY_ADDRESS=

# RPC URLs
ARBITRUM_SEPOLIA_RPC=https://arb-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ETHEREUM_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# CRE Workflow Configuration
CRE_WORKFLOW_ADDRESS=
SAFE_ADDRESS=

# Frontend
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_GUARDIAN_ADDRESS=${GUARDIAN_ADDRESS}
NEXT_PUBLIC_RISK_REGISTRY_ADDRESS=${RISK_REGISTRY_ADDRESS}
