# Paladin Protocol - CRE Workflow Environment Variables

# Blockchain Configuration
ARBITRUM_SEPOLIA_RPC=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# AI Configuration (Local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Block Explorer API Keys
ARBISCAN_API_KEY=your_arbiscan_api_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Contract Addresses
GUARDIAN_ADDRESS=0x0000000000000000000000000000000000000000
RISK_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000001

# CRE Workflow Configuration
CRE_WORKFLOW_PRIVATE_KEY=your_cre_workflow_private_key_here
TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Deployment Private Key (fallback)
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here
